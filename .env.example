# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# Security
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY_HOURS=24

# LLM Backend (OpenAI)
OPENAI_API_KEY=sk-...

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
